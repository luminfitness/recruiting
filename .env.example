# Postgres — Neon pooled/transaction-mode connection string (NOT the one-shot
# HTTP fetch driver's URL). Required for SET LOCAL-based RLS context to work.
# Get this from your Neon project's "Connect" dialog -> "Connection string"
# (pooled connection, port 5432 via PgBouncer). Example shape:
# postgres://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
#
# This role must NOT have BYPASSRLS — every table's RLS policy defaults to
# zero rows without an app.current_org_id set, which is what makes it safe.
DATABASE_URL=

# A SEPARATE Postgres role WITH BYPASSRLS, used only by: the cron-tick's
# cross-org enumeration, the magic-link login flow's initial email lookup,
# and migrate.ts/seed.ts. Create it once per Neon project:
#   CREATE ROLE usapt_service WITH LOGIN PASSWORD '...' BYPASSRLS;
#   GRANT ALL ON ALL TABLES IN SCHEMA public TO usapt_service;
# then use that role's connection string here.
SERVICE_DATABASE_URL=

# Bearer secret the external scheduler (GitHub Actions workflow) must present
# to call POST /api/cron/tick. Generate with: openssl rand -hex 32
CRON_SECRET=

# Bearer secret the inbound-email provider (SendGrid Inbound Parse / Postmark)
# must present to POST /api/webhooks/inbound-email. Generate with: openssl rand -hex 32
INBOUND_WEBHOOK_SECRET=

# Symmetric key (32 bytes, base64) used to encrypt integration_configs.credentials_encrypted.
# Generate with: openssl rand -base64 32
INTEGRATION_CREDENTIALS_KEY=

# Session/magic-link signing secret. Generate with: openssl rand -hex 32
AUTH_SECRET=

# Base URL used to build magic-link / candidate token URLs in dev.
APP_BASE_URL=http://localhost:3000
