{
  "name": "@usapt/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "dev:db:start": "tsx src/dev-db.ts start",
    "dev:db:stop": "tsx src/dev-db.ts stop",
    "dev:db:reset": "tsx src/dev-db.ts reset",
    "test": "vitest run"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.0",
    "@types/pg": "^8.11.0",
    "embedded-postgres": "18.4.0-beta.17",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^2.1.0"
  }
}
